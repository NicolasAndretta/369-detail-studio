# ── Panel de galería (/admin) ────────────────────────────────
# Copiar este archivo como `.env.local` y completar los valores.
# NUNCA commitear `.env.local` (ya está en .gitignore).

# Supabase → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clave con la que entran Nico y el primo al panel
ADMIN_PASSWORD=

# Secreto para firmar la sesión (cualquier texto largo al azar)
ADMIN_SESSION_SECRET=
